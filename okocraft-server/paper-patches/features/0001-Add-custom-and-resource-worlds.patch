+        // okocraft end - Add custom worlds
 
         // ((DedicatedServer) this.server).forceDifficulty();
 
@@ -151,14 +184,46 @@ public record PaperWorldLoader(MinecraftServer server, String levelId) {
         if (loading == null) {
             return;
         }
+    // okocraft start - Add custom worlds
+        this.loadWorld(stem, this.loadWorldGenSettings(hasWorldData, loading), loading);
+    }
 
-        final WorldGenSettings worldGenSettings = !hasWorldData
+    // Custom worlds reuse the vanilla LevelStem keys (overworld/nether/end), but the shared
+    // server LevelStem belongs to the default world (which may be a void world). Resolve the
+    // LevelStem from each world's own world_gen_settings so that its stored generator and
+    // biome source are used instead of the default world's.
+    private void loadCustomWorld(final boolean hasWorldData, final WorldLoadingInfoAndData loading) {
+        final WorldGenSettings worldGenSettings = this.customWorldGenSettings(hasWorldData, loading);
+        final LevelStem stem = worldGenSettings.dimensions().get(loading.info().stemKey())
+            .orElseThrow(() -> new IllegalStateException("Missing dimension " + loading.info().stemKey().identifier() + " in world gen settings for " + loading.data().bukkitName()));
+        this.loadWorld(stem, worldGenSettings, loading);
+    }
+
+    private WorldGenSettings customWorldGenSettings(final boolean hasWorldData, final WorldLoadingInfoAndData loading) {
+        // If the custom world has not been generated yet, create a fresh normal world with a new
+        // random seed instead of failing or inheriting the (possibly void) default world's generator.
+        if (hasWorldData && !java.nio.file.Files.isDirectory(this.server.storageSource.getDimensionPath(loading.info().dimensionKey()))) {
+            MinecraftServer.LOGGER.info("Custom world '{}' has not been generated yet; creating a new world", loading.data().bukkitName());
+            return new WorldGenSettings(
+                net.minecraft.world.level.levelgen.WorldOptions.defaultWithRandomSeed(),
+                net.minecraft.world.level.levelgen.presets.WorldPresets.createNormalWorldDimensions(this.server.worldLoaderContext.datapackWorldgen())
+            );
+        }
+        return this.loadWorldGenSettings(hasWorldData, loading);
+    }
+
+    private WorldGenSettings loadWorldGenSettings(final boolean hasWorldData, final WorldLoadingInfoAndData loading) {
+        return !hasWorldData
             ? this.server.getWorldGenSettings()
             : loadWorldGenSettings(
             this.server.storageSource,
             this.server.worldLoaderContext.datapackWorldgen(),
             loading.info().dimensionKey()
         );
+    }
+
+    private void loadWorld(final LevelStem stem, final WorldGenSettings worldGenSettings, final WorldLoadingInfoAndData loading) {
+    // okocraft end - Add custom worlds
         final var worldDataAndGenSettings = new LevelDataAndDimensions.WorldDataAndGenSettings(this.server.getWorldData(), worldGenSettings);
 
         if (loading.info().dimensionKey() == Level.OVERWORLD) {
