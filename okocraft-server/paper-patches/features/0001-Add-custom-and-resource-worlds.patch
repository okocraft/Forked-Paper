@@ -126,6 +126,34 @@ public record PaperWorldLoader(MinecraftServer server, String levelId) {
 
         return data;
     }
+    // okocraft start - Add custom worlds
+    private java.util.List<WorldLoadingInfoAndData> loadCustomWorlds() {
+        java.util.List<net.okocraft.paper.CustomWorld> worlds = new java.util.ArrayList<>();
+
+        try {
+            worlds.addAll(net.okocraft.paper.CustomWorld.readCustomWorldFile(java.nio.file.Path.of("custom-worlds.txt")));
+            worlds.addAll(net.okocraft.paper.CustomWorld.readResourceNumberFile(java.nio.file.Path.of("resource-world-number.txt")));
+        } catch (IOException e) {
+            throw new RuntimeException("Cannot load custom worlds", e);
+        }
+
+        java.util.List<WorldLoadingInfoAndData> loaded = new java.util.ArrayList<>(worlds.size());
+        for (net.okocraft.paper.CustomWorld world : worlds) {
+            WorldLoadingInfo info = new WorldLoadingInfo(world.environment(), world.stemKey(), world.dimensionKey(), true);
+
+            try {
+                WorldFolderMigration.migrateStartupWorld(this.server.storageSource, this.server.registryAccess(), world.name(), info.stemKey(), info.dimensionKey());
+            } catch (final IOException e) {
+                throw new RuntimeException("Failed to migrate world storage for " + world.name(), e);
+            }
+
+            LoadedWorldData data = loadWorldData(this.server, world.dimensionKey(), world.name());
+            loaded.add(new WorldLoadingInfoAndData(info, data));
+        }
+
+        return loaded;
+    }
+    // okocraft end - Add custom worlds
 
     public void loadInitialWorlds() {
         final var levelStemRegistry = this.server.registryAccess().lookupOrThrow(Registries.LEVEL_STEM);
@@ -138,6 +166,12 @@ public record PaperWorldLoader(MinecraftServer server, String levelId) {
             }
             this.loadInitialWorld(stem, hasWorldData);
         }
+        // okocraft start - Add custom worlds
+        for (final WorldLoadingInfoAndData world : this.loadCustomWorlds()) {
+            LevelStem stem = levelStemRegistry.getValueOrThrow(world.info().stemKey());
+            this.loadWorld(stem, hasWorldData, world);
+        }
+        // okocraft end - Add custom worlds
 
