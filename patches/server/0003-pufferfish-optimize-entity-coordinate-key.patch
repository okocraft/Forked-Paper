Subject: [PATCH] pufferfish optimize entity coordinate key


diff --git a/src/main/java/net/minecraft/server/MCUtil.java b/src/main/java/net/minecraft/server/MCUtil.java
index 6939ef9b1fe782980e77c351d8a385a573d6a8e6..a93b578fb24a12f029e24b9b1b7905ea2fd52a4c 100644
--- a/src/main/java/net/minecraft/server/MCUtil.java
+++ b/src/main/java/net/minecraft/server/MCUtil.java
@@ -207,7 +207,9 @@ public final class MCUtil {
     }
 
     public static long getCoordinateKey(final Entity entity) {
-        return ((long)(MCUtil.fastFloor(entity.getZ()) >> 4) << 32) | ((MCUtil.fastFloor(entity.getX()) >> 4) & 0xFFFFFFFFL);
+        // okocraft start - Pufferfish Optimize-entity-coordinate-key.patch
+        return ((long)(entity.blockPosition().getZ() >> 4) << 32) | ((entity.blockPosition().getX() >> 4) & 0xFFFFFFFFL); // Pufferfish - eliminate double->long cast in hotpath
+        // okocraft end
     }
 
     public static long getCoordinateKey(final ChunkPos pair) {
